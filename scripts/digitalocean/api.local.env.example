# Copy to api.local.env (gitignored) and fill in. No quotes needed unless value has spaces.
# Generate crypto secrets: openssl rand -hex 32

# Required when using external Managed PostgreSQL (recommended for production reliability).
# Example:
# DATABASE_URL=postgresql://doadmin:...@primerpeso-managed-pg-do-user-...db.ondigitalocean.com:25060/defaultdb?sslmode=require
DATABASE_URL=

AUTH_SECRET=
MASTER_KEY=
HASH_KEY=

# DigitalOcean Spaces: same region as app (e.g. nyc3). Create bucket + keys in the DO control panel.
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=primer-peso-bucket
MINIO_ENDPOINT=nyc3.digitaloceanspaces.com
MINIO_REGION=nyc3

XAI_API_KEY=

# Real SMTP (e.g. SendGrid, Mailgun) — example values will not send mail
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=

# CORS allowlist for API.
# WARNING: '*' is intentionally permissive and high-risk in production.
ALLOWED_ORIGINS=*

# Runtime migration toggle (optional operational override):
# - Keep true in production to ensure app schema migrations run on startup.
AUTO_MIGRATE_APP=true
